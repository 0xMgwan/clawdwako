generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id                String              @id @default(cuid())
  name              String?
  email             String?             @unique
  emailVerified     DateTime?
  image             String?
  accounts          Account[]
  sessions          Session[]
  bots              Bot[]
  openclawInstances OpenClawInstance[]
  subscription      Subscription?
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Bot {
  id                  String      @id @default(cuid())
  userId              String
  user                User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  name                String
  telegramBotToken    String      @unique
  telegramBotUsername String
  selectedModel       String      // claude-opus, gpt-5, gemini
  status              String      @default("pending") // pending, deploying, active, stopped, failed
  railwayProjectId    String?
  railwayServiceId    String?
  deploymentUrl       String?
  deployedAt          DateTime?
  anthropicApiKey     String?     // User's Anthropic API key
  openaiApiKey        String?     // User's OpenAI API key
  googleApiKey        String?     // User's Google AI API key
  createdAt           DateTime    @default(now())
  updatedAt           DateTime    @updatedAt
  deployment          Deployment?
}

model Deployment {
  id              String   @id @default(cuid())
  botId           String   @unique
  bot             Bot      @relation(fields: [botId], references: [id], onDelete: Cascade)
  railwayProjectId String
  railwayServiceId String
  deploymentId    String
  status          String   @default("provisioning") // provisioning, building, deploying, active, failed
  logs            Json?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model ApiUsage {
  id            String   @id @default(cuid())
  botId         String
  model         String   // claude-opus, gpt-5, gemini
  provider      String   // anthropic, openai, google
  inputTokens   Int      @default(0)
  outputTokens  Int      @default(0)
  totalTokens   Int      @default(0)
  estimatedCost Float    @default(0)
  requestType   String   // message, api_call
  success       Boolean  @default(true)
  errorMessage  String?
  metadata      Json?    // Additional data like model version, temperature, etc.
  createdAt     DateTime @default(now())

  @@index([botId])
  @@index([createdAt])
  @@index([model])
}

model Payment {
  id                String   @id @default(cuid())
  userId            String
  sessionId         String   @unique // Snippe session ID
  reference         String?  // Snippe payment reference
  amount            Int      // Amount in cents (e.g., 2000 = $20)
  currency          String   @default("USD")
  package           String   // "starter", "professional", "enterprise"
  status            String   @default("pending") // pending, completed, failed
  checkoutUrl       String?  // Snippe checkout URL
  metadata          Json?    // Additional payment data
  completedAt       DateTime?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([userId])
  @@index([sessionId])
  @@index([status])
}

model ActivityLog {
  id        String   @id @default(cuid())
  botId     String
  type      String   // message, api_call, error, webhook
  content   String
  metadata  Json?
  createdAt DateTime @default(now())

  @@index([botId])
  @@index([createdAt])
  @@index([type])
}

model ConversationMessage {
  id              String   @id @default(cuid())
  botId           String
  chatId          String   // Telegram chat ID
  role            String   // user, assistant, system
  content         String   @db.Text
  toolCalls       Json?    // Tool calls made in this message
  toolResults     Json?    // Results from tool executions
  model           String   // Which model generated this
  tokenCount      Int      @default(0)
  createdAt       DateTime @default(now())

  @@index([botId, chatId])
  @@index([chatId])
  @@index([createdAt])
}

model AgentMemory {
  id              String   @id @default(cuid())
  botId           String
  chatId          String   // Telegram chat ID
  memoryType      String   // fact, preference, task, context, skill
  key             String   // Memory identifier (e.g., "user_name", "favorite_language")
  value           String   @db.Text
  importance      Int      @default(5) // 1-10, higher = more important
  lastAccessed    DateTime @default(now())
  accessCount     Int      @default(0)
  metadata        Json?    // Additional context
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([botId, chatId])
  @@index([chatId])
  @@index([memoryType])
  @@index([importance])
  @@unique([botId, chatId, key])
}

model ConversationSummary {
  id              String   @id @default(cuid())
  botId           String
  chatId          String   // Telegram chat ID
  summary         String   @db.Text
  messageCount    Int      @default(0)
  startDate       DateTime
  endDate         DateTime
  topics          Json?    // Array of topics discussed
  createdAt       DateTime @default(now())

  @@index([botId, chatId])
  @@index([chatId])
  @@index([createdAt])
}

model OpenClawInstance {
  id                String    @id @default(cuid())
  userId            String
  user              User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  // Deployment info
  railwayProjectId  String    @unique
  railwayServiceId  String    @unique
  deploymentUrl     String?
  
  // Configuration
  name              String    @default("My OpenClaw")
  model             String    // "claude-opus-4.5", "gpt-5.2", "gemini-3-flash"
  channel           String    // "telegram", "discord", "whatsapp"
  status            String    @default("deploying") // "deploying", "active", "stopped", "failed", "error"
  
  // Encrypted API Keys
  anthropicKey      String?   @db.Text
  openaiKey         String?   @db.Text
  googleKey         String?   @db.Text
  
  // Encrypted Channel Tokens
  telegramToken     String?   @db.Text
  discordToken      String?   @db.Text
  whatsappToken     String?   @db.Text
  
  // Metrics
  apiCalls          Int       @default(0)
  messageCount      Int       @default(0)
  uptime            Float     @default(0)
  lastActive        DateTime?
  lastHealthCheck   DateTime?
  
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  @@index([userId])
  @@index([status])
  @@index([createdAt])
}

model Subscription {
  id                      String   @id @default(cuid())
  userId                  String   @unique
  user                    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  // Subscription details
  tier                    String   @default("starter") // "starter", "pro", "enterprise"
  status                  String   @default("active") // "active", "cancelled", "past_due", "trialing"
  
  // Stripe integration
  stripeCustomerId        String?  @unique
  stripeSubscriptionId    String?  @unique
  stripePriceId           String?
  
  // Limits based on tier
  maxInstances            Int      @default(1)
  maxApiCalls             Int      @default(10000)
  
  // Billing period
  currentPeriodStart      DateTime
  currentPeriodEnd        DateTime
  cancelAtPeriodEnd       Boolean  @default(false)
  
  // Trial
  trialStart              DateTime?
  trialEnd                DateTime?
  
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt

  @@index([userId])
  @@index([status])
  @@index([stripeCustomerId])
  @@index([stripeSubscriptionId])
}
